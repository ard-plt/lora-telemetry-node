#pragma once

// ============================================================================
// ŞABLON — bu dosyayı "common/secrets.h" olarak KOPYALA ve WEB_CONFIG_SALT
// değerini kendi takımına/üretim partine özgü rastgele bir değerle değiştir.
//
//   cp common/secrets.h.example common/secrets.h
//
// common/secrets.h GERÇEK tuzu içerir ve .gitignore'da listelidir — asla
// repoya commit edilmemeli. Her takım/parti kendi tuzunu üretip yalnızca
// kendi build makinesinde/CI secret store'unda saklamalı.
//
// Rastgele bir tuz üretmek için (Linux/macOS):
//   openssl rand -hex 32
// ============================================================================

// AP config şifresi bu tuz + cihaz MAC'i HMAC-SHA256 ile türetilir
// (bkz. common/web_config.h: generateApPassword()). Tuz gizli kaldığı sürece
// AP şifresi, beacon frame'de açıkça yayınlanan BSSID/MAC'ten tahmin edilemez.
#define WEB_CONFIG_SALT "DEGISTIR-bu-sadece-bir-sablon-degeri-gercek-build-icin-KULLANMA"
